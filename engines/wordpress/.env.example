# ─────────────────────────────────────────────────────────────────────────────
#  .env.example — WordPress Directory Scraper
# ─────────────────────────────────────────────────────────────────────────────
#
#  Copy this file to .env and fill in real values:
#    cp .env.example .env
#
#  NEVER commit .env to version control — it is listed in .gitignore.
#  This file (.env.example) is safe to commit: it contains no real values.
#
#  Values set here override the equivalent fields in config.yaml at runtime.
#  The scraper loads .env automatically via python-dotenv.
# ─────────────────────────────────────────────────────────────────────────────


# Raw Cookie header value for directories that require an authenticated session.
#
# How to capture your cookies:
#   1. Log in to the target directory site in Chrome or Firefox.
#   2. Open DevTools (F12) → Network tab → reload the page.
#   3. Click any request to the target domain → Headers tab.
#   4. Find the "Cookie:" line under Request Headers.
#   5. Copy the entire value (everything after "Cookie: ") and paste below.
#
# Overrides the cookies_raw key in config.yaml when set.
# Cookies expire — if you start receiving HTTP 401/403 responses, refresh this.
#
# Example (do not use real values here):
#   SCRAPER_COOKIES_RAW=session_id=abc123; auth_token=xyz456; wp_user=def789
SCRAPER_COOKIES_RAW=


# HTTP or HTTPS proxy for routing all scraper requests.
# Useful for IP rotation or bypassing rate limits.
#
# Format:  http://username:password@host:port
#          http://host:port  (if no authentication required)
#
# Overrides the proxy key in config.yaml when set.
# Leave blank if you do not need a proxy.
#
# Example (do not use real values here):
#   SCRAPER_PROXY=http://user:pass@proxy.example.com:8080
SCRAPER_PROXY=
